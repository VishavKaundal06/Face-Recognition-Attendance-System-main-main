# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/smart_attendance

# Server Port
PORT=3000

# JWT Secret
JWT_SECRET=your_jwt_secret

# SMTP Email (for admin password reset OTP)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
MAIL_FROM=HPTU Attendance <no-reply@yourdomain.com>

# OTP Settings
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SEC=60
OTP_MAX_ATTEMPTS=5
